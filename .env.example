# ===== CONFIGURAÇÕES DO SERVIDOR =====

# Porta do servidor (padrão: 3000)
PORT=3000

# Chave secreta para JWT (MUDE EM PRODUÇÃO!)
# Gere uma chave forte: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=tr-sped-secret-key-change-in-production

# Ambiente (development, production)
NODE_ENV=production

# ===== INSTRUÇÕES =====
# 1. Copie este arquivo para .env
# 2. Altere JWT_SECRET para uma chave forte e única
# 3. Ajuste PORT se necessário
# 4. Adicione .env ao .gitignore (já está)
